---
interface Props {
  title: string;
  slug: string;
  category: string;
  tags: string[];
  servings: number;
  prepTime?: string;
  cookTime?: string;
  image?: string;
}

const { title, slug, category, tags, servings, prepTime, cookTime, image } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

function slugifyTag(tag: string) {
  return tag
    .toLowerCase()
    .trim()
    .replace(/ä/g, 'ae')
    .replace(/ö/g, 'oe')
    .replace(/ü/g, 'ue')
    .replace(/ß/g, 'ss')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const categoryEmojis: Record<string, string> = {
  'Hauptspeise': '🍲',
  'Beilagen': '🥗',
  'Dessert': '🍰',
  'Brot & Gebäck': '🥖',
  'Frühstück': '🥞',
  'Dips & Saucen': '🏺',
  'Basics & Komponenten': '🧪'
};

const emoji = categoryEmojis[category] || '🍽️';
---

<article class="recipe-card">
  <a href={`${baseUrl}/${slug}`} class="recipe-card-link">
    {image ? (
      <img src={`${baseUrl}${image}`} alt={title} class="recipe-card-image" loading="lazy" />
    ) : (
      <div class="recipe-card-placeholder">
        <span>{emoji}</span>
      </div>
    )}
  </a>

  <div class="recipe-card-content">
    <div class="recipe-card-category">{category}</div>
    <h3 class="recipe-card-title">
      <a href={`${baseUrl}/${slug}`}>{title}</a>
    </h3>

    <div class="tag-list">
      {tags.slice(0, 3).map(tag => (
        <a href={`${baseUrl}/tags/${slugifyTag(tag)}`} class="tag-badge">#{tag}</a>
      ))}
    </div>

    <div class="recipe-card-meta">
      <span>⏱️ {prepTime || '15 Min'}</span>
      <span>👥 {servings} Portionen</span>
    </div>
  </div>
</article>
