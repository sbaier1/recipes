---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';

const allRecipes = await getCollection('recipes');

// Sort recipes alphabetically by title
allRecipes.sort((a, b) => a.data.title.localeCompare(b.data.title));

const categories = [
  'Alle',
  'Hauptspeise',
  'Beilagen',
  'Dessert',
  'Brot & Gebäck',
  'Frühstück',
  'Dips & Saucen',
  'Basics & Komponenten'
];

const popularTags = ['vegan', 'vegetarisch', 'schnell', 'airfryer', 'mezze', 'süß', 'herzhaft'];
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Übersicht & Suche">
  <section style="background: linear-gradient(180deg, var(--color-primary-light) 0%, var(--color-bg) 100%); padding: 3.5rem 0 2rem; border-bottom: 1px solid var(--color-border-subtle);">
    <div class="container" style="text-align: center;">
      <h1 style="font-size: 2.75rem; margin-bottom: 0.75rem;">Meine Rezept-Sammlung</h1>
      <p style="font-size: 1.15rem; color: var(--color-text-muted); max-width: 600px; margin: 0 auto 1.5rem;">
        {allRecipes.length} handverlesene Rezepte aus Google Keep. Mit automatischer Zutatenskalierung, interaktiver Koch-Checkliste & Blitz-Suche.
      </p>

      <!-- Search Input -->
      <div class="search-container">
        <span class="search-icon">🔍</span>
        <input 
          type="search" 
          id="recipeSearch" 
          class="search-input" 
          placeholder="Rezept, Zutat oder Schlagwort suchen... (z.B. Pancakes, Falafel, Tofu)" 
          autocomplete="off"
        />
      </div>

      <!-- Categories Navigation Pills -->
      <div class="filter-bar" style="justify-content: center;">
        {categories.map(cat => (
          <button 
            class={`filter-btn ${cat === 'Alle' ? 'active' : ''}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Popular Tags -->
      <div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
        <span style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted);">Beliebte Tags:</span>
        {popularTags.map(tag => (
          <button class="tag-badge tag-filter-btn" data-tag={tag} style="cursor: pointer; border: 1px solid var(--color-border);">
            #{tag}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="container" style="padding: 2.5rem 1.5rem 4rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h2 id="sectionTitle" style="font-size: 1.5rem;">Alle Rezepte ({allRecipes.length})</h2>
      <span id="resultCount" style="font-size: 0.9rem; color: var(--color-text-muted);"></span>
    </div>

    <div class="recipe-grid" id="recipeGrid">
      {allRecipes.map(recipe => (
        <div 
          class="recipe-grid-item" 
          data-title={recipe.data.title.toLowerCase()}
          data-category={recipe.data.category}
          data-tags={JSON.stringify(recipe.data.tags)}
        >
          <RecipeCard 
            title={recipe.data.title}
            slug={recipe.slug}
            category={recipe.data.category}
            tags={recipe.data.tags}
            servings={recipe.data.servings}
            prepTime={recipe.data.prepTime}
            cookTime={recipe.data.cookTime}
            image={recipe.data.image}
          />
        </div>
      ))}
    </div>

    <div id="noResults" style="display: none; text-align: center; padding: 4rem 1rem; color: var(--color-text-muted);">
      <p style="font-size: 3rem; margin-bottom: 0.5rem;">🔍</p>
      <h3>Keine Rezepte gefunden</h3>
      <p>Versuche einen anderen Suchbegriff oder passe die Filter an.</p>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('recipeSearch');
      const categoryBtns = document.querySelectorAll('.filter-btn');
      const tagBtns = document.querySelectorAll('.tag-filter-btn');
      const gridItems = document.querySelectorAll('.recipe-grid-item');
      const sectionTitle = document.getElementById('sectionTitle');
      const noResults = document.getElementById('noResults');

      let activeCategory = 'Alle';
      let activeTag = null;
      let searchQuery = '';

      function filterRecipes() {
        let visibleCount = 0;

        gridItems.forEach(item => {
          const title = item.getAttribute('data-title') || '';
          const category = item.getAttribute('data-category') || '';
          const tags = JSON.parse(item.getAttribute('data-tags') || '[]');

          const matchesCategory = activeCategory === 'Alle' || category === activeCategory;
          const matchesTag = !activeTag || tags.includes(activeTag);
          const matchesSearch = !searchQuery || title.includes(searchQuery) || tags.some(t => t.includes(searchQuery)) || category.toLowerCase().includes(searchQuery);

          if (matchesCategory && matchesTag && matchesSearch) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (sectionTitle) {
          const catLabel = activeCategory !== 'Alle' ? ` - ${activeCategory}` : '';
          const tagLabel = activeTag ? ` (#${activeTag})` : '';
          sectionTitle.textContent = `Rezepte (${visibleCount})${catLabel}${tagLabel}`;
        }

        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      }

      searchInput?.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        filterRecipes();
      });

      categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeCategory = btn.getAttribute('data-category') || 'Alle';
          filterRecipes();
        });
      });

      tagBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const tag = btn.getAttribute('data-tag');
          if (activeTag === tag) {
            activeTag = null;
            btn.style.opacity = '1';
          } else {
            tagBtns.forEach(b => b.style.opacity = '0.6');
            activeTag = tag;
            btn.style.opacity = '1';
          }
          filterRecipes();
        });
      });
    });
  </script>
</Layout>
